# Retrieval / indexing
RAG_DATA_DIR=./paper
RAG_FILE_GLOB=**/*.pdf
RAG_FAISS_INDEX_DIR=./.cache/faiss
RAG_EMBEDDING_MODEL=bge-m3
RAG_TOP_K=5
RAG_FETCH_K=20
RAG_SCORE_THRESHOLD=0.35
RAG_QUERY_REWRITE_ENABLED=false
RAG_QUERY_REWRITE_MODEL=qwen2.5:0.5b
RAG_QUERY_REWRITE_TEMPERATURE=0.0
RAG_QUERY_REWRITE_MAX_VARIANTS=3
RAG_QUERY_REWRITE_CACHE_TTL_SEC=30
RAG_QUERY_REWRITE_CACHE_MAX_SIZE=512
RAG_RETRIEVAL_CACHE_TTL_SEC=15
RAG_RETRIEVAL_CACHE_MAX_SIZE=256

# Reader service
RAG_READER_ARTIFACT_DIR=./artifacts/readers/run_best
RAG_READER_MAX_LENGTH=384
RAG_READER_MAX_ANSWER_LENGTH=30
RAG_READER_N_BEST_SIZE=20
RAG_READER_MIN_SPAN_SCORE=0.0
RAG_READER_REQUIRE_METADATA=true
READER_SERVICE_MAX_BATCH_SIZE=16
READER_SERVICE_BATCH_TIMEOUT_MS=20

# LLM synthesis
RAG_LLM_MODEL=qwen2.5:0.5b
RAG_TEMPERATURE=0.2
RAG_READER_SERVICE_URL=http://reader:8081
RAG_READER_SERVICE_TIMEOUT_SEC=30
